<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Centro Operativo Dorado</title>
  <link rel="stylesheet" href="styles.css"/>
</head>
<body>
  <div class="scene">
    <div class="desk-edge"></div>
    <div class="board board-left"></div>
    <div class="board board-right"></div>
    <div class="cabinet cab-left"></div>
    <div class="cabinet cab-right"></div>
  </div>

  <header class="topbar">
    <div class="brand">
      <span class="mark">🐾</span>
      <span>Centro Operativo Dorado</span>
    </div>
    <nav class="topnav">
      <button class="navbtn" data-view="dashboard">Dashboard</button>
      <button class="navbtn" data-view="proyectos">Proyectos</button>
      <button class="navbtn" data-view="bitacora">Bitácora</button>
      <button class="navbtn" data-view="modulos">Módulos</button>
      <button class="navbtn" data-view="importexport">Import/Export</button>
      <a class="navbtn" href="/centro-operativo-dorado/apps/">APPS</a>
      <a class="navbtn" href="ideas/">Ideas</a>
      <a class="navbtn" href="manual.html">Manual</a>
    </nav>
    <div class="row syncrow">
      <button id="btn-sync" class="primary">Sincronizar ahora</button>
      <span id="sync-status" class="small">Sincronización: —</span>
    </div>
  </header>

  <main class="wrap">
    <section id="view-dashboard" class="view">
      <h1>Dashboard</h1>
      <div class="grid">
        <div class="card">
          <h3>Resumen</h3>
          <div class="kpis">
            <div><span id="kpi-total">0</span><small>Total proyectos</small></div>
            <div><span id="kpi-activos">0</span><small>Activos</small></div>
            <div><span id="kpi-pausados">0</span><small>Pausados</small></div>
            <div><span id="kpi-completos">0</span><small>Completos</small></div>
          </div>
        </div>
        <div class="card">
          <h3>Próximos pasos</h3>
          <ul id="dash-next" class="list"></ul>
        </div>
      </div>
    </section>

    <section id="view-proyectos" class="view hidden">
      <div class="row">
        <h1>Proyectos</h1>
        <button id="btn-new" class="primary">+ Nuevo</button>
      </div>

      <div class="card">
        <div class="row">
          <input id="q" placeholder="Buscar por nombre, etiqueta o estado"/>
          <select id="f-estado">
            <option value="">Todos</option>
            <option value="activo">Activo</option>
            <option value="pausado">Pausado</option>
            <option value="completo">Completo</option>
          </select>
        </div>
      </div>

      <div id="list-proyectos" class="list grid"></div>
    </section>

    <section id="view-bitacora" class="view hidden">
      <h1>Bitácora</h1>
      <div class="card">
        <div class="row">
          <input id="bit-text" placeholder="Registrar avance, decisión o nota…"/>
          <button id="bit-add" class="primary">Agregar</button>
        </div>
        <div id="bit-list" class="list"></div>
      </div>
    </section>

    <section id="view-modulos" class="view hidden">
      <h1>Módulos</h1>
      <div class="card" style="margin-bottom:12px">
        <div class="small">Guarda la ruta local (Termux) para cada módulo:</div>
        <div class="row" style="margin:8px 0">
          <input id="new-module-name" placeholder="Nombre del módulo" />
          <input id="new-module-path" placeholder="/data/data/..." />
          <input id="new-module-url" placeholder="https://..." />
          <button id="btn-add-module">Agregar módulo</button>
          <button id="btn-clear-modules" style="background:#a94442;color:white;">🗑 Borrar módulos</button>
        </div>
        <div id="module-paths" class="list"></div>
      </div>
      <div class="grid">
        <a class="card link" href="modulos/mama-salud/index.html">Salud</a>
        <a class="card link" href="modulos/abc-de-vicky/index.html">Educación</a>
        <a class="card link" href="modulos/audio-sagrado/index.html">Impresión 3D</a>
        <a class="card link" href="modulos/kits-fisica/index.html">Investigación</a>
        <a class="card link" href="modulos/maker-lab/index.html">Maker Lab</a>
      </div>
    </section>

    <section id="view-importexport" class="view hidden">
      <h1>Import/Export</h1>
      <div class="grid">
        <div class="card">
          <h3>Exportar JSON</h3>
          <button id="btn-export" class="primary">Descargar proyectos+bitácora</button>
          <button id="btn-export-all">Descargar TODO (incluye ideas)</button>
        </div>
        <div class="card">
          <h3>Importar JSON</h3>
          <div class="small">Proyectos + bitácora</div>
          <input id="file-import" type="file" accept="application/json"/>
          <div class="small" style="margin-top:8px">TODO (incluye ideas)</div>
          <input id="file-import-all" type="file" accept="application/json"/>
          <div class="small" style="margin-top:8px">Se reemplaza el contenido actual.</div>
          <div class="small" style="margin-top:10px">Cargar desde ruta local (solo servidor local)</div>
          <div class="row">
            <input id="path-input" placeholder="/data/data/.../archivo.json" />
            <button id="btn-load-path">Cargar ruta</button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <dialog id="dlg" class="dlg">
    <form method="dialog" id="form-proyecto">
      <h2 id="dlg-title">Nuevo proyecto</h2>
      <input type="hidden" id="p-id"/>
      <label>Nombre</label>
      <input id="p-nombre" required/>
      <label>Estado</label>
      <select id="p-estado">
        <option value="activo">Activo</option>
        <option value="pausado">Pausado</option>
        <option value="completo">Completo</option>
      </select>
      <label>Etiquetas (separadas por coma)</label>
      <input id="p-tags"/>
      <label>Próximo paso</label>
      <input id="p-next"/>
      <label>Ruta local (Termux)</label>
      <input id="p-path" placeholder="/data/data/com.termux/files/home/..."/>
      <label>URL del proyecto</label>
      <input id="p-url" placeholder="https://..."/>
      <label>URL local del proyecto</label>
      <input id="p-url-local" placeholder="http://127.0.0.1:8000/..."/>
      <label>Notas</label>
      <textarea id="p-notas" rows="4"></textarea>
      <div class="row">
        <button value="cancel">Cancelar</button>
        <button id="p-save" class="primary" value="default">Guardar</button>
      </div>
    </form>
  </dialog>

  <script src="app.js"></script>
  <script>
    const btnClearModules = document.getElementById("btn-clear-modules");
    if (btnClearModules) {
      btnClearModules.addEventListener("click", () => {
        if (confirm("¿Seguro que deseas borrar todos los módulos guardados?")) {
          localStorage.removeItem("modulos");
          localStorage.removeItem("modulos_config");
          localStorage.removeItem("modulos_data");
          alert("Módulos borrados correctamente");
          location.reload();
        }
      });
    }
  </script>

  <script>
  /* COD_BORRAR_MODULOS_POR_FILA */
  (function(){
    const STORAGE_KEY = "cod_modulos_borrados";

    function getDeleted(){
      try{
        return JSON.parse(localStorage.getItem(STORAGE_KEY)) || [];
      }catch(e){
        return [];
      }
    }

    function setDeleted(arr){
      localStorage.setItem(STORAGE_KEY, JSON.stringify(arr));
    }

    function normalize(text){
      return String(text || "")
        .replace(/\s+/g, " ")
        .trim()
        .toLowerCase();
    }

    function getRowTitle(row){
      const selectors = ["strong", "label", "h3", "h4", ".titulo", ".module-title"];
      for(const sel of selectors){
        const el = row.querySelector(sel);
        if(el && el.textContent.trim()){
          return el.textContent.trim();
        }
      }

      const directText = Array.from(row.childNodes)
        .filter(n => n.nodeType === Node.TEXT_NODE)
        .map(n => n.textContent.trim())
        .filter(Boolean)
        .join(" ")
        .trim();

      if(directText) return directText.split(" / ")[0].trim();

      const text = row.textContent.replace(/Guardar|Abrir URL|Abrir Local|Borrar/g, "").trim();
      return text.split("\n")[0].trim();
    }

    function hideQuickButton(title){
      const norm = normalize(title);
      const allButtons = Array.from(document.querySelectorAll("button, a"));
      for(const btn of allButtons){
        const txt = normalize(btn.textContent);
        if(txt === norm){
          const wrap = btn.closest("div") || btn;
          wrap.style.display = "none";
        }
      }
    }

    function removeModuleRow(row, title){
      const deleted = getDeleted();
      const norm = normalize(title);
      if(!deleted.includes(norm)){
        deleted.push(norm);
        setDeleted(deleted);
      }
      hideQuickButton(title);
      row.remove();
    }

    function shouldHide(title){
      return getDeleted().includes(normalize(title));
    }

    function styleDeleteButton(btn){
      btn.style.background = "#a94442";
      btn.style.color = "white";
      btn.style.padding = "8px 12px";
      btn.style.border = "none";
      btn.style.borderRadius = "10px";
      btn.style.marginLeft = "8px";
      btn.style.cursor = "pointer";
      btn.style.whiteSpace = "nowrap";
    }

    function addDeleteButtons(){
      const candidates = Array.from(document.querySelectorAll("div, li, section"))
        .filter(row => {
          const text = row.textContent || "";
          const hasGuardar = /Guardar/.test(text);
          const hasAbrir = /Abrir URL|Abrir Local/.test(text);
          const hasInput = row.querySelector("input");
          return (hasGuardar || hasAbrir) && hasInput;
        });

      candidates.forEach(row => {
        if(row.dataset.codDeleteReady === "1") return;

        const title = getRowTitle(row);
        if(!title) return;

        if(shouldHide(title)){
          hideQuickButton(title);
          row.remove();
          return;
        }

        const btn = document.createElement("button");
        btn.textContent = "Borrar";
        btn.type = "button";
        btn.className = "cod-btn-borrar-modulo";
        styleDeleteButton(btn);

        btn.addEventListener("click", function(){
          const ok = confirm('¿Deseas borrar el módulo "' + title + '"?');
          if(!ok) return;
          removeModuleRow(row, title);
        });

        let anchor =
          Array.from(row.querySelectorAll("button, a")).find(el =>
            /Guardar|Abrir URL|Abrir Local/.test(el.textContent || "")
          );

        if(anchor && anchor.parentNode){
          anchor.insertAdjacentElement("afterend", btn);
        } else {
          row.appendChild(btn);
        }

        row.dataset.codDeleteReady = "1";
      });
    }

    function hideDeletedQuickButtonsOnLoad(){
      const deleted = getDeleted();
      deleted.forEach(name => {
        const allButtons = Array.from(document.querySelectorAll("button, a"));
        for(const btn of allButtons){
          const txt = normalize(btn.textContent);
          if(txt === name){
            const wrap = btn.closest("div") || btn;
            wrap.style.display = "none";
          }
        }
      });
    }

    function init(){
      addDeleteButtons();
      hideDeletedQuickButtonsOnLoad();
    }

    if(document.readyState === "loading"){
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }

    setTimeout(init, 500);
    setTimeout(init, 1200);
  })();
  </script>

</body>
</html>
